# Leantime API Configuration
LEANTIME_URL=https://your-leantime-instance.com

# Authentication — set EITHER LEANTIME_API_KEY or LEANTIME_PAT (PAT wins if both).
#
# LEANTIME_API_KEY: company API key. The user that OWNS this key is the acting
# "bot" — it both authors everything the agent writes and is what whoami
# (Auth.getUserId) returns. No user ID/email is configured for the bot; it is
# resolved from this key. Use this for the shared deployment (e.g. LM Studio).
LEANTIME_API_KEY=your_api_key_here

# LEANTIME_PAT: Personal Access Token (sent as Authorization: Bearer). When set,
# the MCP authenticates as the TOKEN'S HUMAN OWNER instead of the bot — i.e. the
# AI agent operates the person's own account. Use this for a personal agent
# (Claude Code / Codex / ...). REQUIRES the PersonalAccessTokenAuth plugin on the
# Leantime server (the core JSON-RPC endpoint does not accept Bearer tokens by
# itself). See LEANTIME_MCP_SETUP_FOR_AI_AGENTS.md for how to issue a token.
# LEANTIME_PAT=your_personal_access_token

# Optional: display name of the AI agent operating this MCP (e.g. "Claude Code",
# "Codex", "LM Studio"). When set, comments get a "Co-Authored-By: <name>"
# trailer so readers can see which agent produced them. Applies in BOTH auth
# modes (API key and PAT). Leave unset for non-AI/general API integrations.
# LEANTIME_AGENT_NAME=Claude Code

# Optional: email of the human operating the agent (their OIDC account).
# Resolved to a user ID via lookup (never set the ID directly) and used as the
# default assignee for tickets the bot creates. Leave empty/unset for no
# default — callers can instead target a user per call via the assignee_email
# argument on create_ticket / assign_ticket (handy for a shared deployment).
LEANTIME_TARGET_USER_EMAIL=person-operating-the-agent@example.com

# Optional: minimum Leantime role required for WRITE/destructive tools
# (create/update/patch/delete/assign/comment/timesheet/milestone). Read tools
# are never gated. Leantime's API does NOT enforce role-based write
# restrictions, so this MCP enforces it: a write is allowed only if the acting
# user's (the API key owner's) role is >= this value.
#   Leantime roles: readonly=5, commenter=10, editor=20, manager=30,
#                    admin=40, owner=50
# Default 20 (editor). Set to 5 to effectively make the server read-only when
# the bot is a readonly(5) user; lower it (e.g. 0) to allow all writes.
LEANTIME_WRITE_MIN_ROLE=20
