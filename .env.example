# Leantime API Configuration
LEANTIME_URL=https://your-leantime-instance.com

# API key. The user that OWNS this key is the author of everything the agent
# writes (cannot be overridden per call).
LEANTIME_API_KEY=your_api_key_here

# Acting user for whoami / my-tickets. Set ONE of the following:
# Recommended: the numeric user ID that owns the API key above (keeps the
# acting identity consistent with the token owner).
LEANTIME_ACTOR_USER_ID=your_user_id_here
# Legacy fallback: email resolved to a user (may NOT match the token owner).
# LEANTIME_USER_EMAIL=your_user_email_here
