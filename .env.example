# Leantime API Configuration
LEANTIME_URL=https://your-leantime-instance.com

# API key. The user that OWNS this key is the acting "bot" — it both authors
# everything the agent writes and is what whoami (Auth.getUserId) returns.
# No user ID/email is configured for the bot; it is resolved from this key.
LEANTIME_API_KEY=your_api_key_here

# Optional: email of the human operating the agent (their OIDC account).
# Resolved to a user ID via lookup (never set the ID directly) and used as the
# default assignee for tickets the bot creates. Leave empty/unset for no
# default — callers can instead target a user per call via the assignee_email
# argument on create_ticket / assign_ticket (handy for a shared deployment).
LEANTIME_TARGET_USER_EMAIL=person-operating-the-agent@example.com

# Optional: minimum Leantime role required for WRITE/destructive tools
# (create/update/patch/delete/assign/comment/timesheet/milestone). Read tools
# are never gated. Leantime's API does NOT enforce role-based write
# restrictions, so this MCP enforces it: a write is allowed only if the acting
# user's (the API key owner's) role is >= this value.
#   Leantime roles: readonly=5, commenter=10, editor=20, manager=30,
#                    admin=40, owner=50
# Default 20 (editor). Set to 5 to effectively make the server read-only when
# the bot is a readonly(5) user; lower it (e.g. 0) to allow all writes.
LEANTIME_WRITE_MIN_ROLE=20
